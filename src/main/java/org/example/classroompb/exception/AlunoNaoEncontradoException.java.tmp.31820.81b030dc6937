package org.example.classroompb.exception;

/**
 * RF29: Lançada quando a matrícula informada não corresponde a um aluno existente.
 */
public class AlunoNaoEncontradoException extends ConsultaFrequenciaException {

    private static final long serialVersionUID = 1L;

    public AlunoNaoEncontradoException(String matricula) {
        super("Aluno não encontrado: " + matricula);
    }
}